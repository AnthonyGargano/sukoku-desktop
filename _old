const size = 9

// ---------- Strict Sudoku Logic (unique & solvable) ----------

type board [size][size]int

func (b *board) clone() board { var c board; c = *b; return c }

func (b *board) isSafe(r, c, v int) bool {
	// check row & column
	for i := 0; i < size; i++ {
		if b[r][i] == v || b[i][c] == v {
			return false
		}
	}
	// check 3x3 box
	br, bc := (r/3)*3, (c/3)*3
	for i := br; i < br+3; i++ {
		for j := bc; j < bc+3; j++ {
			if b[i][j] == v {
				return false
			}
		}
	}
	return true
}

func (b *board) findEmpty() (int, int, bool) {
	for r := 0; r < size; r++ {
		for c := 0; c < size; c++ {
			if b[r][c] == 0 {
				return r, c, true
			}
		}
	}
	return -1, -1, false
}

// randomized full backtracking fill (produce a solved grid)
func generateSolved() board {
	var b board
	var fill func(int, int) bool
	fill = func(r, c int) bool {
		if r == size {
			return true
		}
		nr, nc := r, c+1
		if nc == size {
			nr, nc = r+1, 0
		}
		perm := rand.Perm(9)
		for _, x := range perm {
			v := x + 1
			if b.isSafe(r, c, v) {
				b[r][c] = v
				if fill(nr, nc) {
					return true
				}
				b[r][c] = 0
			}
		}
		return false
	}
	_ = fill(0, 0) // by construction this succeeds
	return b
}

// count solutions up to 'limit' (early exit > limit)
func solveCount(b *board, limit int) int {
	count := 0
	var dfs func() bool
	dfs = func() bool {
		if count > limit {
			return true // early stop
		}
		r, c, ok := b.findEmpty()
		if !ok {
			count++
			return count > limit
		}
		// try 1..9
		for v := 1; v <= 9; v++ {
			if b.isSafe(r, c, v) {
				b[r][c] = v
				if dfs() { // early bailout if > limit
					b[r][c] = 0
					return true
				}
				b[r][c] = 0
			}
		}
		return false
	}
	dfs()
	return count
}

// dig cells while preserving uniqueness; retry if we can't reach target clues
func makeUniquePuzzle(targetClues int) (puzzle board, solution board) {
	tries := 0
	for {
		tries++
		solved := generateSolved()
		p := solved.clone()

		// random removal order
		order := rand.Perm(81)
		removed := 0
		goalRemove := 81 - targetClues

		for _, idx := range order {
			if removed >= goalRemove {
				break
			}
			r, c := idx/9, idx%9
			if p[r][c] == 0 {
				continue
			}
			save := p[r][c]
			p[r][c] = 0

			test := p.clone()
			if solveCount(&test, 1) == 1 { // still exactly one solution
				removed++
			} else {
				p[r][c] = save // revert removal
			}
		}

		// final safety check
		final := p.clone()
		if solveCount(&final, 1) == 1 {
			return p, solved
		}
		// if we didn’t reach target clues or uniqueness failed, loop & regenerate
		if tries > 10 {
			// relax: accept the best we got that is unique, else regenerate anyway
			// (in practice we usually succeed long before this)
		}
	}
}


// ---------- UI model ----------
type cell struct {
	row, col   int
	value      int
	fixed      bool
	bg         *canvas.Rectangle
	txt        *canvas.Text
}

// a minimal custom widget that renders bg+text and receives taps
type tapCell struct {
	widget.BaseWidget
	cell    *cell
	onTap   func(*cell)
	size    fyne.Size
	pos     fyne.Position
}
func newTapCell(c *cell, onTap func(*cell)) *tapCell {
	t := &tapCell{cell: c, onTap: onTap}
	t.ExtendBaseWidget(t)
	return t
}
func (t *tapCell) CreateRenderer() fyne.WidgetRenderer {
	// stack background and text
	cont := container.NewMax(t.cell.bg, t.cell.txt)
	return widget.NewSimpleRenderer(cont)
}
func (t *tapCell) Tapped(*fyne.PointEvent) { if t.onTap != nil { t.onTap(t.cell) } }
func (t *tapCell) TappedSecondary(*fyne.PointEvent) {}

func main() {
	rand.Seed(time.Now().UnixNano())
	a := app.New()
	w := a.NewWindow("Sudoku")

	// colors & sizing
	bgWhite   := color.NRGBA{255, 255, 255, 255}
	hlRowCol  := color.NRGBA{230, 242, 255, 255}
	hlSame    := color.NRGBA{204, 255, 204, 255}
	hlSelected:= color.NRGBA{0, 114, 206, 100}
	userColor := color.NRGBA{0, 0, 0, 255}
	givenColor:= color.NRGBA{30, 30, 30, 255}
	const cellPx  = float32(48)
	const textPt  = float32(22)

	// board data & UI
	cells := make([][]*cell, size)
	var selected *cell
	var solution board

	// absolute-position grid (always visible)
	grid := container.NewWithoutLayout()
	grid.Resize(fyne.NewSize(cellPx*size, cellPx*size))

	// helpers
	setCell := func(cl *cell, v int, given bool) {
		cl.value = v
		cl.fixed = given
		if v == 0 {
			cl.txt.Text = ""
		} else {
			cl.txt.Text = strconv.Itoa(v)
		}
		if given {
			cl.txt.Color = givenColor
			cl.txt.TextStyle = fyne.TextStyle{Bold: true}
		} else {
			cl.txt.Color = userColor
			cl.txt.TextStyle = fyne.TextStyle{Bold: false}
		}
		cl.txt.Refresh()
	}
	refreshHighlights := func() {
		for _, row := range cells {
			for _, cl := range row { cl.bg.FillColor = bgWhite }
		}
		if selected != nil {
			for i := 0; i < size; i++ {
				cells[selected.row][i].bg.FillColor = hlRowCol
				cells[i][selected.col].bg.FillColor = hlRowCol
			}
			for _, row := range cells {
				for _, cl := range row {
					if cl.value != 0 && selected.value != 0 && cl.value == selected.value {
						cl.bg.FillColor = hlSame
					}
				}
			}
			selected.bg.FillColor = hlSelected
		}
		canvas.Refresh(grid)
	}

	// Build cells with enhanced 3x3 section borders
	// Build cells (thin cell borders only)
	for r := 0; r < size; r++ {
	    row := make([]*cell, size)
	    for c := 0; c < size; c++ {
	        bg := canvas.NewRectangle(bgWhite)
	        bg.StrokeColor = color.NRGBA{0, 0, 0, 255}
	        bg.StrokeWidth = 1 // keep thin; thick section lines are added separately

	        txt := canvas.NewText("", userColor)
	        txt.TextSize = textPt
	        txt.Alignment = fyne.TextAlignCenter

	        cl := &cell{row: r, col: c, bg: bg, txt: txt}
	        tc := newTapCell(cl, func(sel *cell) { selected = sel; refreshHighlights() })

	        // Absolute placement
	        tc.Resize(fyne.NewSize(cellPx, cellPx))
	        tc.Move(fyne.NewPos(float32(c)*cellPx, float32(r)*cellPx))

	        bg.Resize(fyne.NewSize(cellPx, cellPx))
	        bg.Move(fyne.NewPos(float32(c)*cellPx, float32(r)*cellPx))

	        txt.Resize(fyne.NewSize(cellPx, cellPx))
	        txt.Move(fyne.NewPos(float32(c)*cellPx, float32(r)*cellPx))

	        grid.Add(tc)
	        row[c] = cl
	    }
	    cells[r] = row
	}

// --- Thick 3×3 lines overlay + compose a fixed-size board ---

boardSize := fyne.NewSize(cellPx*size, cellPx*size)

// draw thick 3×3 separators and outer border on a separate layer
linesLayer := container.NewWithoutLayout()

makeVLine := func(x float32, thick bool) {
    ln := canvas.NewLine(color.NRGBA{0, 0, 0, 255})
    if thick { ln.StrokeWidth = 4 } else { ln.StrokeWidth = 2 }
    ln.Position1 = fyne.NewPos(x, 0)
    ln.Position2 = fyne.NewPos(x, boardSize.Height)
    linesLayer.Add(ln)
}
makeHLine := func(y float32, thick bool) {
    ln := canvas.NewLine(color.NRGBA{0, 0, 0, 255})
    if thick { ln.StrokeWidth = 4 } else { ln.StrokeWidth = 2 }
    ln.Position1 = fyne.NewPos(0, y)
    ln.Position2 = fyne.NewPos(boardSize.Width, y)
    linesLayer.Add(ln)
}

// outer thick border
makeVLine(0, true)
makeVLine(boardSize.Width, true)
makeHLine(0, true)
makeHLine(boardSize.Height, true)

// 3×3 separators (at 3 and 6)
for i := 1; i <= 2; i++ {
    x := float32(3*i) * cellPx
    y := float32(3*i) * cellPx
    makeVLine(x, true)
    makeHLine(y, true)
}

// Transparent spacer enforces a non-zero MinSize (so centering works)
spacer := canvas.NewRectangle(color.NRGBA{0, 0, 0, 0})
spacer.SetMinSize(boardSize)

// IMPORTANT: draw order in NewMax = bottom..top.
// We want the thick lines ON TOP of the cells so they’re visible.
board := container.NewMax(
    spacer,    // enforces MinSize
    grid,      // cells (widgets)
    linesLayer, // thick 3×3 separators + outer border (on top)
)
board.Resize(boardSize)



	// wrap grid in a holder so Center works perfectly
	gridHolder := container.NewMax(grid)
	gridHolder.Resize(grid.Size())
	centered := container.NewCenter(gridHolder)

	// game actions
	newPuzzle := func(clues int) {
		p, solved := makeUniquePuzzle(clues)
		solution = solved

		for r := 0; r < size; r++ {
			for c := 0; c < size; c++ {
				v := p[r][c]
				if v != 0 {
					setCell(cells[r][c], v, true)  // given
				} else {
					setCell(cells[r][c], 0, false) // empty
				}
			}
		}
		selected = nil
		refreshHighlights()	
	}

	checkPuzzle := func() {
		for r := 0; r < size; r++ {
			for c := 0; c < size; c++ {
				if cells[r][c].value != solution[r][c] {
					selected = cells[r][c]
					refreshHighlights()
					dialog.ShowInformation("Result", "❌ Incorrect at row "+strconv.Itoa(r+1)+", col "+strconv.Itoa(c+1), w)
					return
				}
			}
		}
		dialog.ShowInformation("Result", "✅ Solved correctly!", w)
	}
	
	// toolbar
	diff := widget.NewSelect([]string{"Easy", "Medium", "Hard"}, nil)
	diff.SetSelected("Medium")

	top := container.NewHBox(
		widget.NewLabel("Difficulty:"),
		diff,
		layout.NewSpacer(),
		widget.NewButton("New Puzzle", func() {
			switch diff.Selected {
			case "Easy":  newPuzzle(40)
			case "Hard":  newPuzzle(25)
			default:      newPuzzle(32)
			}
		}),
		widget.NewButton("Check", func() { checkPuzzle() }),
	)

// Proper centering (center the fixed-size board)
centered = container.NewCenter(board)
content := container.NewBorder(
    top, nil, nil, nil,
    container.NewPadded(
        container.NewVBox(
            layout.NewSpacer(),
            centered,
            layout.NewSpacer(),
        ),
    ),
)
w.SetContent(content)

	// keyboard entry
	w.Canvas().SetOnTypedKey(func(ev *fyne.KeyEvent) {
		if selected == nil || selected.fixed { return }
		switch ev.Name {
		case fyne.KeyDelete, fyne.KeyBackspace, fyne.Key0:
			setCell(selected, 0, false)
		default:
			k := string(ev.Name)
			if len(k) == 1 {
				if v, err := strconv.Atoi(k); err == nil && v >= 1 && v <= 9 {
					setCell(selected, v, false)
				}
			}
		}
		refreshHighlights()
	})

	// Proper window sizing: always large enough to show entire board
	var windowWidth, windowHeight float32
	windowWidth = cellPx*size + 280
	windowHeight = cellPx*size + 220
	w.Resize(fyne.NewSize(windowWidth, windowHeight))
	newPuzzle(32)
	w.ShowAndRun()
}
